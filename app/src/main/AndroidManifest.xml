<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Lets us enumerate launchable apps for the whitelist editor without
         the QUERY_ALL_PACKAGES special permission. CATEGORY_HOME is
         separate from CATEGORY_LAUNCHER - the home/launcher app itself
         registers under HOME, not LAUNCHER, so without this declared here
         too, Android 11+ package visibility rules silently filter it out
         of queryIntentActivities() results even though the app icon list
         works fine - meaning the launcher app itself couldn't be found or
         whitelisted from the Apps list. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.HOME" />
        </intent>
    </queries>

    <!-- Requested so SettingsActivity can deep-link the user to the OS
         "ignore battery optimizations" dialog. ColorOS's own battery
         manager (see docs/COLOROS.md) is separate and must be handled
         manually; this permission only affects stock Android's doze list. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- AccessibilityWatchdogService's whole purpose - restoring
         ContentGuardService to enabled_accessibility_services if the OS
         strips it (confirmed happening under ColorOS's "Hide apps"). Like
         every other app doing this (MacroDroid included), this can only
         ever be granted via a one-time adb command, never at runtime by
         the app itself:
         adb shell pm grant <applicationId> android.permission.WRITE_SECURE_SETTINGS -->
    <uses-permission
        android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Lets the N-strikes lockout ask the OS to kill the offending app's
         background process, not just navigate away from it - a normal,
         install-time-granted permission, no adb/root needed. Documented as
         a hint the OS can decline, not a guaranteed kill the way Settings'
         own "Force Stop" button is (that's a signature-protected API
         unavailable to third-party apps). -->
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.ContentGuard"
        android:supportsRtl="true">

        <activity
            android:name=".ui.SettingsActivity"
            android:exported="true"
            android:theme="@style/Theme.ContentGuard"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".admin.ContentGuardDeviceAdminReceiver"
            android:label="@string/app_name"
            android:description="@string/device_admin_description"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin_receiver" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <service
            android:name=".service.ContentGuardService"
            android:label="@string/app_name"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <service
            android:name=".service.AccessibilityWatchdogService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Restores this app's own accessibility permission if the OS revokes it (e.g. ColorOS Hide Apps), so content-filtering protection can't be silently disabled." />
        </service>

        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
